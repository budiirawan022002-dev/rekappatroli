{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.9.0",
            "excludeFiles": "{template_web/**,foto/**,ss/**,hasil/**,laporan_v1/**}"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "VERCEL_SUPPORT_LARGE_FUNCTIONS": "1"
    }
}